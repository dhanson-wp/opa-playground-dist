{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Opa — try it",
		"description": "A small, welcoming place to write online. This Playground spins up a fresh Opa instance in your browser. No account, no install. Click around, write a post, see what it feels like.",
		"author": "opa",
		"categories": ["WordPress", "Blogging"]
	},
	"preferredVersions": {
		"php": "8.2",
		"wp": "6.7"
	},
	"phpExtensionBundles": ["kitchen-sink"],
	"features": {
		"networking": true
	},
	"login": true,
	"siteOptions": {
		"blogname": "Field Journal",
		"blogdescription": "Plain notes from anywhere."
	},
	"steps": [
		{
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://github.com/dhanson-wp/opa-playground-dist/raw/main/dist/opa-theme.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/dhanson-wp/opa-playground-dist/raw/main/dist/opa-platform.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require_once '/wordpress/wp-load.php'; foreach ( get_posts( array( 'post_type' => array( 'post', 'page' ), 'post_status' => 'any', 'numberposts' => -1 ) ) as $p ) { wp_delete_post( $p->ID, true ); } update_option( 'opa_external_signout_url', 'https://opa.blog/' ); ?>"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Field Journal",
				"blogdescription": "Plain notes from anywhere.",
				"default_ping_status": "closed",
				"default_comment_status": "closed",
				"show_on_front": "posts",
				"posts_per_page": 5
			}
		},
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		}
	],
	"landingPage": "/wp-admin/admin.php?page=opa"
}
